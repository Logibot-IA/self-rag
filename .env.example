# Digital Ocean GenAI Platform
# Obtenha sua chave em: cloud.digitalocean.com/gen-ai
DO_API_KEY=your_digitalocean_api_key_here
DO_BASE_URL=https://inference.do-ai.run/v1
DO_MODEL=openai-gpt-oss-120b

# Hugging Face
# Obtenha seu token em: huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# LangSmith (opcional — para rastreamento e observabilidade)
# Obtenha sua chave em: smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=benchmark-self-rag
